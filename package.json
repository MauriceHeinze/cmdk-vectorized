{
  "name": "cmdk-vectorized",
  "version": "0.1.1",
  "description": "Vector-database search hooks and speech-to-text voice input for cmdk command palettes. Weaviate tooling and agentic intent-map CLI.",
  "type": "module",
  "bin": {
    "cmdk-vectorized": "dist/cli.js",
    "cmdk-vectorized-agent": "dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/MauriceHeinze/cmdk-vectorized#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauriceHeinze/cmdk-vectorized.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "keywords": [
    "cmdk",
    "command-palette",
    "command-menu",
    "semantic-search",
    "vector-search",
    "vector-database",
    "weaviate",
    "react",
    "react-hooks",
    "shadcn",
    "speech-to-text",
    "voice-commands",
    "intent-map",
    "command-k"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tooling": {
      "types": "./dist/tooling.d.ts",
      "import": "./dist/tooling.js",
      "require": "./dist/tooling.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "llms.txt",
    "docs/api.md",
    "docs/llm-guide.md",
    "docs/local-weaviate.md",
    "skills"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "lint": "tsc --noEmit",
    "example:redux:dev": "pnpm --dir examples/settings-demo-redux dev",
    "example:redux:typecheck": "pnpm --dir examples/settings-demo-redux typecheck",
    "example:redux:build": "pnpm --dir examples/settings-demo-redux build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "cmdk": "^1.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
